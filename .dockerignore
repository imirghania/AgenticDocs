# Python build artifacts
.venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Version control
.git/
.gitignore

# Secrets — never bake into the image; mount via env_file at runtime
.env
.env.*
!.env.example

# Runtime-generated data (bind-mounted as volumes in docker-compose)
output/
sessions/

# IDE / tool caches
.claude/
.chainlit/
.vscode/
.idea/

# Docs that don't belong in the image
*.md
!README.md
