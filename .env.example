# LLM configuration (REQUIRED)
# Your API key for the chosen provider (Anthropic or OpenAI)
LLM_API_KEY=your_api_key_here

# LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Model name — examples:
#   Anthropic: claude-sonnet-4-5, claude-opus-4-5, claude-haiku-4-5-20251001
#   OpenAI:    gpt-4o, gpt-4o-mini
LLM_MODEL=claude-sonnet-4-5

# Sampling temperature (0.0 = deterministic, higher = more creative)
LLM_TEMPERATURE=0.0

# Web search (recommended)
# Required for the package discovery phase; omit to skip web search
TAVILY_API_KEY=your_tavily_key_here

# LangSmith tracing (optional)
# Enables LangSmith run tracing — safe to leave commented out
# LANGSMITH_API_KEY=your_langsmith_key_here

# App port (optional, default: 8501)
# APP_PORT=8501

# PostgreSQL checkpointer (optional)
# Falls back to SQLite (sessions/checkpoints.db) when unset.
# Start the postgres service with: docker compose --profile postgres up
# The hostname "postgres" resolves to the compose service defined in docker-compose.yml.
#
# POSTGRES_URL=postgresql://agenticdocs:agenticdocs@postgres:5432/agenticdocs
# POSTGRES_USER=agenticdocs
# POSTGRES_PASSWORD=agenticdocs

# Redis long-term store (optional)
# Falls back to FilesystemStore (sessions/store/) when unset.
# Start the redis service with: docker compose --profile redis up
#
# REDIS_URL=redis://redis:6379/0

# Full stack (postgres + redis)
# docker compose --profile full up
