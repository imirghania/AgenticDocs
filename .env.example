# Environment variables for documentation enhancer agent
llm_API_KEY=your_llm_api_key_here
llm_provider=your_llm_provider_here

# Optional: PostgreSQL checkpointer (falls back to SQLite if unset)
POSTGRES_URL=postgresql://user:password@localhost:5432/docsmith

# Optional: Redis long-term store (falls back to InMemoryStore if unset)
REDIS_URL=redis://localhost:6379/0

# Session storage directory (default: sessions/)
SESSION_DIR=sessions